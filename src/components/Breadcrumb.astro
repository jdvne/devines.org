---
interface BreadcrumbItem {
  path: string;
  label: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<h1 class="breadcrumb">
  <span class="homeWrapper">
    <a href="/" class="link">devines<span class="operator">.</span>org</a>
  </span>
  {items?.map((item, index) => (
    <span>
      <span class="operator">.</span>
      {index === items.length - 1 ? (
        <>
          <span class="method">{item.label}</span>
          <span class="parens">()</span>
          <span class="operator">;</span>
        </>
      ) : (
        <a href={item.path} class="link">{item.label}</a>
      )}
    </span>
  ))}
</h1>

<style>
.breadcrumb {
  color: white;
  margin: 0;
  position: relative;
  font-size: clamp(1rem, 4vw, 1.5rem);
  line-height: 1.5;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.1em;
  word-break: break-word;
}

.homeWrapper {
  display: inline-flex;
  align-items: center;
}

.link {
  color: white;
  text-decoration: none;
  position: relative;
  display: inline-flex;
  align-items: center;
  padding: 0.15em 0;
}

.link:hover {
  text-decoration: underline;
  text-underline-offset: 4px;
}

.operator {
  color: #c586c0;
  user-select: none;
  display: inline-flex;
  align-items: center;
}

.method {
  color: #dcdcaa;
  user-select: none;
  display: inline-flex;
  align-items: center;
  padding: 0.15em 0;
}

.parens {
  color: rgba(255, 255, 255, .55);
  user-select: none;
  display: inline-flex;
  align-items: center;
}

@media (max-width: 480px) {
  .breadcrumb {
    font-size: clamp(0.875rem, 3.5vw, 1rem);
    gap: 0.05em;
  }

  .link, .method {
    padding: 0.1em 0;
  }
}
</style>
