---
import BaseLayout from '../layouts/BaseLayout.astro';
import travelData from '../data/travel.yml';
import trailsMeta from '../data/trails.yml';

const locations = travelData;

const trails = (trailsMeta ?? []).map(({ file, name, type, date, caption, color }) => ({
  file, name, type, date, caption, color,
}));
---

<BaseLayout title="travel - devines.org" bodyClass="travel-body">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/maplibre-gl@4/dist/maplibre-gl.min.css" />

  <div id="travel-main">
    <div id="map"></div>

    <nav class="overlay-nav">
      <a href="/">devines.org</a>
      <span class="sep">/</span>
      <span>travel</span>
    </nav>

    <div id="info-panel" class="info-panel hidden">
      <button id="info-close" aria-label="close">✕</button>
      <div id="info-name" class="info-name"></div>
      <div id="info-date" class="info-date"></div>
      <div id="info-caption" class="info-caption"></div>
    </div>

    <div id="legend" class="legend hidden"></div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ locations, trails }}>
  window.__travel = { locations, trails };
</script>
<script>
  import '../scripts/travel.js';
</script>

<style>
:global(.travel-body) {
  background: #7A251E;
  margin: 0;
  padding: 0;
  overflow: hidden;
}

#travel-main {
  position: fixed;
  inset: 0;
}

#map {
  width: 100%;
  height: 100%;
}

/* MapLibre controls */
:global(.maplibregl-ctrl-zoom-in),
:global(.maplibregl-ctrl-zoom-out) {
  background-color: rgba(26, 8, 0, 0.85) !important;
  border-color: #3D1916 !important;
}

:global(.maplibregl-ctrl-zoom-in span),
:global(.maplibregl-ctrl-zoom-out span) {
  filter: invert(0.85) sepia(0.3);
}

:global(.maplibregl-ctrl-group) {
  background: transparent !important;
  border: 1px solid #3D1916 !important;
  box-shadow: none !important;
}

:global(.maplibregl-ctrl-attrib) {
  background: rgba(26, 8, 0, 0.6) !important;
  color: rgba(215, 201, 167, 0.5) !important;
  font-size: 0.65rem !important;
}

:global(.maplibregl-ctrl-attrib a) {
  color: rgba(215, 201, 167, 0.5) !important;
}

.overlay-nav {
  position: absolute;
  top: 1rem;
  left: 1rem;
  display: flex;
  align-items: center;
  gap: 0.5em;
  font-family: 'Courier New', Courier, monospace;
  font-size: 0.85rem;
  color: #D7C9A7;
  background: rgba(26, 8, 0, 0.75);
  padding: 0.4em 0.75em;
  border-radius: 4px;
  backdrop-filter: blur(4px);
  z-index: 10;
}

.overlay-nav a,
.overlay-nav a:visited,
.overlay-nav a:link {
  color: #D7C9A7;
  text-decoration: none;
  opacity: 0.6;
  transition: opacity 0.2s;
}

.overlay-nav a:hover {
  opacity: 1;
}

.overlay-nav .sep {
  opacity: 0.3;
}

:global(.travel-marker) {
  cursor: pointer;
  filter: drop-shadow(0 2px 3px rgba(0, 0, 0, 0.35));
  transition: transform 0.15s, filter 0.15s;
}

:global(.travel-marker:hover) {
  transform: scale(1.25) translateY(-2px);
  filter: drop-shadow(0 4px 6px rgba(223, 189, 34, 0.5));
}

.info-panel {
  position: absolute;
  bottom: 2rem;
  left: 1rem;
  background: rgba(26, 8, 0, 0.85);
  border: 1px solid #3D1916;
  border-left: 2px solid #DFBD22;
  color: #D7C9A7;
  font-family: 'Courier New', Courier, monospace;
  padding: 0.75rem 2.5rem 0.75rem 1rem;
  border-radius: 4px;
  backdrop-filter: blur(4px);
  min-width: 200px;
  max-width: 280px;
  z-index: 10;
  transition: opacity 0.15s;
}

.info-panel.hidden {
  opacity: 0;
  pointer-events: none;
}

.info-name {
  font-size: 0.9rem;
  color: #D7C9A7;
}

.info-date {
  font-size: 0.72rem;
  color: rgba(215, 201, 167, 0.5);
  margin-top: 0.2rem;
}

.info-caption {
  font-size: 0.78rem;
  color: rgba(215, 201, 167, 0.6);
  margin-top: 0.25rem;
}

#info-close {
  position: absolute;
  top: 0.5rem;
  right: 0.5rem;
  background: none;
  border: none;
  color: rgba(215, 201, 167, 0.4);
  cursor: pointer;
  font-size: 0.75rem;
  padding: 0;
  line-height: 1;
  transition: color 0.2s;
}

#info-close:hover {
  color: #D7C9A7;
}

.legend {
  position: absolute;
  top: 1rem;
  right: 1rem;
  background: rgba(26, 8, 0, 0.75);
  border: 1px solid #3D1916;
  color: #D7C9A7;
  font-family: 'Courier New', Courier, monospace;
  font-size: 0.78rem;
  padding: 0.5rem 0.75rem;
  border-radius: 4px;
  backdrop-filter: blur(4px);
  z-index: 10;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.legend.hidden {
  display: none;
}

.legend table {
  border-collapse: collapse;
}

.legend td {
  padding: 0.2rem 0;
  vertical-align: middle;
}

.legend td:first-child {
  padding-right: 0.4rem;
  text-align: center;
}

.legend td:nth-child(2) {
  padding-right: 0.65rem;
  text-align: center;
}

.legend input[type="checkbox"] {
  cursor: pointer;
  width: 0.75rem;
  height: 0.75rem;
  margin: 0;
}

@media (max-width: 480px) {
  .info-panel {
    min-width: 0;
    max-width: calc(100% - 2rem);
    left: 1rem;
    right: 1rem;
    bottom: 1rem;
    box-sizing: border-box;
  }
}
</style>
