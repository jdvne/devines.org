---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Joshua Devine" bodyClass="home-body">
  <main id="home-main">
    <div class="container">
      <h1>
        <a class="name" href="./">joshua <span class="dev">dev</span>ine</a>
      </h1>
      <div class="resume">
        <div class="resume-section">
          <span class="resume-label">now</span>
          <ul>
            <li>sr. swe @ capital one<span id="tenure"></span></li>
            <li>aws certified solutions architect</li>
          </ul>
        </div>
        <div class="resume-section">
          <span class="resume-label">then</span>
          <ul>
            <li>founder @ devine studios</li>
            <li>comp sci @ uva</li>
          </ul>
        </div>
      </div>
      <nav class="nav">
        <a href="/thoughts" class="navLink">thoughts</a><span class="navSep">/</span>
        <a href="/cookbook" class="navLink">cookbook</a><span class="navSep">/</span>
        <a href="/coffee" class="navLink">coffee</a><span class="navSep">/</span>
        <a href="/slots" class="navLink">slots</a><span class="navSep">/</span>
        <a href="/wedding" class="navLink">wedding</a><span class="navSep">/</span>
        <a href="/travel" class="navLink">travel</a><span class="navSep">/</span>
        <a href="/potd" class="navLink">potd</a>
      </nav>
      <div class="social">
        <a href="https://github.com/jdvne" class="socialLink" target="_blank" rel="noopener">github</a><span class="navSep">/</span>
        <a href="https://www.linkedin.com/in/jdvne/" class="socialLink" target="_blank" rel="noopener">linkedin</a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
:global(.home-body) {
  background: var(--dark-bg);
  margin: 0;
  padding: 0;
}

#home-main {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  min-height: 100vh;
  background: var(--dark-bg);
  font-family: 'Courier New', Courier, monospace;
  color: var(--dark-text);
  overflow-x: hidden;
}

.container {
  padding: 2rem;
  max-width: 800px;
  margin: 0 auto;
}

.container h1 {
  margin: 0 0 2rem;
}

.name {
  text-decoration: none;
  color: var(--dark-text);
  font-size: clamp(1.5rem, 5vw, 2.5rem);
}

.dev {
  color: var(--dark-accent);
  text-decoration: underline wavy var(--dark-accent) 1px;
  text-underline-offset: 3px;
  position: relative;
  cursor: pointer;
}

.dev::after {
  content: '^ i write code';
  position: absolute;
  left: 0.3rem;
  top: 100%;
  font-size: 0.75rem;
  font-style: normal;
  color: var(--dark-accent);
  white-space: nowrap;
  opacity: 0;
  transition: opacity 0.2s;
  pointer-events: none;
  max-width: calc(100vw - 3rem);
  overflow: hidden;
  text-overflow: ellipsis;
}

.dev:hover::after {
  opacity: 1;
}

.nav {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.5rem;
  margin-top: 2.5rem;
}

.navLink {
  color: var(--dark-text-muted);
  text-decoration: none;
  font-size: 1.1rem;
  font-weight: 500;
  transition: color 0.2s;
}

.navLink:hover {
  color: var(--dark-text);
}

.navSep {
  color: var(--dark-text-muted);
  font-size: 1rem;
  user-select: none;
}

.social {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-top: 0.6rem;
}

.socialLink {
  color: var(--dark-text-muted);
  text-decoration: none;
  font-size: 1.1rem;
  font-weight: 500;
  transition: color 0.2s;
}

.socialLink:visited {
  color: var(--dark-text-muted);
}

.socialLink:hover {
  color: var(--dark-text);
}

.socialLink::after {
  content: ' ↗';
  font-size: 0.8rem;
}

.resume {
  margin-top: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  font-size: 1.1rem;
  font-weight: 500;
}

.resume-section {
  display: flex;
  gap: 1rem;
  align-items: flex-start;
}

.resume-label {
  color: var(--dark-accent);
  min-width: 3.5rem;
  flex-shrink: 0;
}

.resume ul {
  margin: 0;
  padding: 0;
  list-style: none;
  color: var(--dark-text-muted);
}

.resume li::before {
  content: '— ';
}
</style>

<script>
  function updateTenure() {
    const start = new Date(2022, 7, 22, 9, 0, 0);
    const now = new Date();

    if (now < start) {
      document.getElementById('tenure').textContent = '';
      return;
    }

    const totalMonths = (now.getFullYear() - start.getFullYear()) * 12 + (now.getMonth() - start.getMonth());
    const rounded = Math.round(totalMonths / 6) / 2;
    const label = rounded === 1 ? 'yr' : 'yrs';

    document.getElementById('tenure').textContent = `, ${rounded} ${label}`;
  }

  updateTenure();
</script>
