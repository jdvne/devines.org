---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

export async function getStaticPaths() {
  const posts = await getCollection('thoughts');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const title = post.data.title || post.slug;
const description = post.data.description || '';
const image = post.data.image || '/images/nyc.jpg';

const formatDate = (date?: Date) => {
  if (!date) return '';
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
};
---

<BaseLayout title={title} description={description} image={image} bodyClass="thought-body">
  <main id="thought-main">
    <div class="container">
      <div class="title">
        <Breadcrumb items={[
          { path: '/thoughts', label: 'thoughts' },
          { path: `/thoughts/${post.slug}`, label: post.slug }
        ]} />
      </div>
      <div class="metadata">
        <h1>{title}</h1>
        {post.data.date && (
          <time class="date">{formatDate(post.data.date)}</time>
        )}
        {description && (
          <p class="description">{description}</p>
        )}
      </div>
      <div class="blog-post">
        <Content />
      </div>
    </div>
  </main>
</BaseLayout>

<style>
:global(.thought-body) {
  background: var(--dark-bg);
  margin: 0;
  padding: 0;
}

#thought-main {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  min-height: 100vh;
  background: var(--dark-bg);
  font-family: 'Courier New', Courier, monospace;
  color: var(--dark-text);
  overflow-x: hidden;
}


.container {
  max-width: 800px;
  margin: 0 auto;
  padding: 2rem;
}

.metadata {
  padding: 1.5rem 0 1.5rem;
  border-bottom: 1px solid var(--dark-bg-deep);
  margin-bottom: 2rem;
}

.metadata h1 {
  margin: 0 0 0.4rem;
  color: var(--dark-text);
  font-size: clamp(1.2rem, 5vw, 1.6em);
}

.date {
  display: block;
  color: var(--dark-text-faint);
  margin-bottom: 0.5rem;
  font-size: 0.8em;
}

.description {
  color: var(--dark-text-muted);
  font-style: italic;
  margin: 0;
  font-size: 0.95em;
}

.blog-post {
  padding: 2rem 0;
}

.blog-post :global(h1) { margin-bottom: 1rem; color: var(--dark-text); }
.blog-post :global(h2) { margin: 2rem 0 1rem; color: var(--dark-accent); }
.blog-post :global(h3) { margin: 1.5rem 0 0.75rem; color: var(--dark-text); }
.blog-post :global(p) { margin-bottom: 1.5rem; line-height: 1.7; color: var(--dark-text); }
.blog-post :global(ul),
.blog-post :global(ol) { margin: 1rem 0; padding-left: 2rem; color: var(--dark-text); }
.blog-post :global(li) { margin-bottom: 0.5rem; line-height: 1.6; }
.blog-post :global(pre) { background: var(--dark-bg-mid); padding: 1rem; border-radius: 4px; overflow-x: auto; margin: 1.5rem 0; border: 1px solid var(--dark-bg-deep); max-width: 100%; box-sizing: border-box; }
.blog-post :global(code) { font-family: 'Courier New', Courier, monospace; font-size: 0.9em; color: var(--dark-text-muted); }
.blog-post :global(img) { max-width: 100%; height: auto; margin: 1.5rem 0; }
.blog-post :global(a) { color: var(--dark-accent); text-decoration: none; }
.blog-post :global(a:hover) { text-decoration: underline; }
.blog-post :global(em) { color: var(--dark-text-muted); }
.blog-post :global(strong) { color: var(--dark-accent); }

@media (max-width: 768px) {
  .container { padding: 1.5rem; }
}
</style>
